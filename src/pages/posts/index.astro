---
import { getD1Binding, listPublishedPosts } from "@/data/ai-post";
import PageLayout from "@/layouts/Base.astro";
import { getFormattedDate } from "@/utils/date";

export const prerender = false;

const db = getD1Binding();
const posts = db ? await listPublishedPosts(db) : [];

const meta = {
	description: "Read my collection of posts from D1",
	title: "Posts",
};
---

<PageLayout meta={meta}>
	<section>
		<h1 class="title mb-12">Posts</h1>
		{
			!db ? (
				<p class="text-muted">D1 binding belum tersedia di runtime ini.</p>
			) : posts.length === 0 ? (
				<p class="text-muted">Belum ada post yang dipublikasikan.</p>
			) : (
				<ul class="space-y-4 text-start">
					{posts.map((post) => (
						<li class="grid gap-1 sm:grid-cols-[auto_1fr] sm:[&_q]:col-start-2">
							<span class="text-muted min-w-30 font-semibold">
								{getFormattedDate(new Date(post.publishAt))}
							</span>
							<div>
								<a class="cactus-link" href={`/posts/${post.slug}/`}>
									{post.title}
								</a>
								<q class="line-clamp-3 italic">{post.description}</q>
							</div>
						</li>
					))}
				</ul>
			)
		}
	</section>
</PageLayout>
