---
import { getD1Binding, listPublishedTags } from "@/data/ai-post";
import PageLayout from "@/layouts/Base.astro";

export const prerender = false; // Ensure SSR runtime for D1-backed tags index page

const db = getD1Binding();
const tags = db ? await listPublishedTags(db) : [];

const meta = {
	description: "Browse all post tags",
	title: "Tags",
};
---

<PageLayout meta={meta}>
	<section>
		<h1 class="title mb-12">Tags</h1>
		{
			!db ? (
				<p class="text-muted">D1 binding belum tersedia di runtime ini.</p>
			) : tags.length === 0 ? (
				<p class="text-muted">Belum ada tag yang tersedia.</p>
			) : (
				<ul class="space-y-4 text-start">
					{tags.map((tag) => (
						<li class="flex items-center gap-2">
							<a class="cactus-link inline-block" href={`/tags/${tag.tag}/`}>
								#{tag.tag}
							</a>
							<span class="text-muted">
								- {tag.count} Post{tag.count > 1 ? "s" : ""}
							</span>
						</li>
					))}
				</ul>
			)
		}
	</section>
</PageLayout>
